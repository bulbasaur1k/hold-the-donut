{
  "log": {
    "loglevel": "debug"
  },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "0.0.0.0",
      "port": 10808,
      "protocol": "socks",
      "settings": {
        "udp": true
      }
    }
  ],
  "outbounds": [
    {
      "tag": "vless-xhttp",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "host.docker.internal",
            "port": 8444,
            "users": [
              {
                "id": "b831381d-6324-4d53-ad4f-8cda48b30811",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "tls",
        "tlsSettings": {
          "serverName": "tunnel.example",
          "alpn": [
            "h2"
          ],
          "pinnedPeerCertSha256": "__CERT_PIN__"
        },
        "xhttpSettings": {
          "host": "tunnel.example",
          "path": "/donut-secret",
          "mode": "stream-up"
        }
      }
    }
  ]
}